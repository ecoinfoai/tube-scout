use flake

# Load secrets (decrypted by agenix → ~/.config/tube-scout/.env)
dotenv_if_exists "$HOME/.config/tube-scout/.env"

# Per-user overrides (e.g. `use flake .#gpu` for cuDNN/NVRTC).
# .envrc.local is gitignored so each developer can pick their shell variant.
source_env_if_exists .envrc.local
